# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/city-zen
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=city-zen
DB_HOST=localhost
DB_PORT=5432

PG_EMAIL=postgres@postgres
PG_PASSWORD=postgres

# Security Settings
USER_SECRET_KEY=user-secret-key
EMPLOYEE_SECRET_KEY=employee-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=960m

# Environment
ENVIRONMENT=development
DEBUG=True

# File Storage
UPLOAD_FOLDER=uploads/

# AI Model Paths
AI_MODEL_PATH=/path/to/your/model
AI_CONFIG_PATH=/path/to/your/config

# Optional External Services
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_USERNAME=your-email@example.com
# EMAIL_PASSWORD=your-email-password

# Logging
LOG_LEVEL=info
CLIENT_URL=localhost:5173
SERVER_PORT=8000